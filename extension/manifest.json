{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "permissions": [
    "storage",
    "tabs",
    "identity",
    "nativeMessaging"
  ],
  "host_permissions": [
    "*://*.crunchyroll.com/*",
    "https://graphql.anilist.co/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.crunchyroll.com/*",
        "*://static.crunchyroll.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Crunchyroll Auto Skip",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "*://*.crunchyroll.com/*"
      ]
    }
  ],
  "default_locale": "en",
  "homepage_url": "https://github.com/IsmaLD/Tsuki-Crunchyroll"
}